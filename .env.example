# 現代語訳などサーバ専用。値はコピーして .env に記入し、.env はコミットしない。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=

# 任意: anthropic | openai
# TRANSLATION_PROVIDER=anthropic

# 接続が不安定なとき（SDK 内部のリトライ回数）
# ANTHROPIC_MAX_RETRIES=5
# OPENAI_MAX_RETRIES=5

# read ETIMEDOUT 対策: リクエスト全体のタイムアウト（ms）。未設定時はスクリプト既定 1200000（20分）
# ANTHROPIC_TIMEOUT_MS=1800000
# OPENAI_TIMEOUT_MS=1800000

# 中間装置で Keep-Alive が切れる場合に 1 を試す
# ANTHROPIC_HTTP_DISABLE_KEEPALIVE=1
# OPENAI_HTTP_DISABLE_KEEPALIVE=1

# 主が anthropic で api.anthropic.com が通らないとき、接続エラー後に OpenAI へ切替（要 OPENAI_*）
# TRANSLATE_FALLBACK_PROVIDER=openai
